      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max_over_time(llamacpp:predicted_tokens_seconds{service=~\"$service\", service!=\"llama-embed\"}[1h])",
          "legendFormat": "{{service}}",
