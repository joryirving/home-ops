      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max_over_time(llamacpp:prompt_tokens_seconds{service=~\"$service\", service!=\"llama-embed\"}[$__range])",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "PP tok/s (peak)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Current generation speed, overlaid by service below.",
      "fieldConfig": {
