{
  "id": null,
  "title": "LiteLLM",
  "tags": ["llm", "litellm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "30s",
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Requests processed in the selected time range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(litellm_proxy_total_requests_metric_total[$__range]))",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ],
      "title": "Requests in Range",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Tokens (input + output) processed in the selected time range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(litellm_total_tokens_metric_total[$__range]))",
          "legendFormat": "Tokens",
          "refId": "A"
        }
      ],
      "title": "Tokens in Range",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Requests currently in-flight",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(litellm_in_flight_requests)",
          "legendFormat": "In-Flight",
          "refId": "A"
        }
      ],
      "title": "In-Flight Requests",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Average total request latency (last 5m)",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(litellm_request_total_latency_metric_sum[5m])) / sum(rate(litellm_request_total_latency_metric_count[5m]))",
          "legendFormat": "Avg Latency",
          "refId": "A"
        }
      ],
      "title": "Avg Request Latency",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "panels": [],
      "title": "Per-Model Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Requests per requested model in the selected time range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": {
        "displayLabels": ["name"],
        "layout": "horizontal",
        "showLegend": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (requested_model) (increase(litellm_proxy_total_requests_metric_total[$__range]))",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "title": "Requests by Requested Model",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Request rate over time by requested model",
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (requested_model) (rate(litellm_proxy_total_requests_metric_total[5m]))",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Requested Model (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Latency percentiles over time by requested model",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, requested_model) (rate(litellm_request_total_latency_metric_bucket[5m])))",
          "legendFormat": "{{requested_model}} p99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, requested_model) (rate(litellm_request_total_latency_metric_bucket[5m])))",
          "legendFormat": "{{requested_model}} p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le, requested_model) (rate(litellm_request_total_latency_metric_bucket[5m])))",
          "legendFormat": "{{requested_model}} p50",
          "refId": "C"
        }
      ],
      "title": "Request Latency by Requested Model",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "LLM API latency (time to get response from model) percentiles",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, model) (rate(litellm_llm_api_latency_metric_bucket[5m])))",
          "legendFormat": "{{model}} p99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(litellm_llm_api_latency_metric_bucket[5m])))",
          "legendFormat": "{{model}} p95",
          "refId": "B"
        }
      ],
      "title": "LLM API Latency by Model",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 11,
      "panels": [],
      "title": "Token Usage by Model",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Tokens (input + output) per requested model in the selected time range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 19 },
      "id": 12,
      "options": { "displayLabels": ["name"], "layout": "horizontal", "showLegend": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (requested_model) (increase(litellm_total_tokens_metric_total[$__range]))",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "title": "Tokens by Requested Model",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Token rate over time by model",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 19 },
      "id": 13,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (requested_model) (rate(litellm_total_tokens_metric_total[5m]))",
          "legendFormat": "{{requested_model}}",
          "refId": "A"
        }
      ],
      "title": "Token Rate by Model (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Input vs output tokens per backend model in the selected time range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 24 },
      "id": 14,
      "options": { "displayLabels": ["name"], "layout": "horizontal", "showLegend": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (model) (increase(litellm_input_tokens_metric_total[$__range]))",
          "legendFormat": "{{model}} input",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (model) (increase(litellm_output_tokens_metric_total[$__range]))",
          "legendFormat": "{{model}} output",
          "refId": "B"
        }
      ],
      "title": "Input vs Output Tokens by Model",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Spend per backend model in the selected time range (local models = $0)",
      "fieldConfig": { "defaults": { "currency": "USD", "unit": "currencyUSD" }, "overrides": [] },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 24 },
      "id": 15,
      "options": { "displayLabels": ["name"], "layout": "horizontal", "showLegend": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (model) (increase(litellm_spend_metric_total[$__range]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Spend by Model in Range",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 16,
      "panels": [],
      "title": "Request Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Failed requests as a percentage of total requests over the last 5m",
      "fieldConfig": { "defaults": { "max": 1, "min": 0, "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 30 },
      "id": 23,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(sum(rate(litellm_proxy_total_requests_metric_total{status_code!~\"2..\"}[5m])) or vector(0)) / clamp_min(sum(rate(litellm_proxy_total_requests_metric_total[5m])), 0.001)",
          "legendFormat": "Failure Rate",
          "refId": "A"
        }
      ],
      "title": "Failure Rate (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Request status codes over time",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 30 },
      "id": 17,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (status_code) (rate(litellm_proxy_total_requests_metric_total[5m]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "title": "Request Status Codes",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Requests by route in the selected time range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 36 },
      "id": 18,
      "options": { "displayLabels": ["name"], "layout": "horizontal", "showLegend": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (route) (increase(litellm_proxy_total_requests_metric_total[$__range]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Requests by Route",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total tokens grouped into provider/subscription buckets over the selected range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 36 },
      "id": 19,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(sum(increase(litellm_total_tokens_metric_total{requested_model=~\"chatgpt/.*\"}[$__range])) or vector(0), \"provider\", \"ChatGPT\", \"\", \"\")",
          "legendFormat": "{{provider}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(sum(increase(litellm_total_tokens_metric_total{requested_model=~\"dsv4f|dsv4p|kimi-k2.6|go-minimax-m3|go-minimax-m2.7|mimo-v2.5|mimo-v2.5-pro|qwen3.7-plus\"}[$__range])) or vector(0), \"provider\", \"Opencode Go\", \"\", \"\")",
          "legendFormat": "{{provider}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(sum(increase(litellm_total_tokens_metric_total{requested_model=~\"glm-5.1|glm-5.2\"}[$__range])) or vector(0), \"provider\", \"GLM Coding Lite\", \"\", \"\")",
          "legendFormat": "{{provider}}",
          "refId": "F"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(sum(increase(litellm_total_tokens_metric_total{requested_model=~\"MiniMax|MiniMax-M2.7\"}[$__range])) or vector(0), \"provider\", \"MiniMax\", \"\", \"\")",
          "legendFormat": "{{provider}}",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "label_replace(sum(increase(litellm_total_tokens_metric_total{requested_model=~\"self-hosted|nvidia|ryzen|qwen3-embedding-0-6b\"}[$__range])) or vector(0), \"provider\", \"Self-hosted\", \"\", \"\")",
          "legendFormat": "{{provider}}",
          "refId": "D"
        }
      ],
      "title": "Tokens by Provider (range)",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 24,
      "panels": [],
      "title": "Token Breakdown & Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total tokens (input + output) across ALL providers and models in the selected range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 43 },
      "id": 25,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(litellm_total_tokens_metric_total[$__range]))",
          "legendFormat": "Total Tokens",
          "refId": "A"
        }
      ],
      "title": "Total Tokens (range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Prompt/input tokens across all models in the selected range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 43 },
      "id": 26,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(litellm_input_tokens_metric_total[$__range]))",
          "legendFormat": "Input",
          "refId": "A"
        }
      ],
      "title": "Input Tokens (range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Completion/output tokens across all models in the selected range",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 43 },
      "id": 27,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(litellm_output_tokens_metric_total[$__range]))",
          "legendFormat": "Output",
          "refId": "A"
        }
      ],
      "title": "Output Tokens (range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "LiteLLM Redis cache hit ratio over the range",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 43 },
      "id": 28,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(litellm_cache_hits_metric_total[$__range])) / clamp_min(sum(increase(litellm_cache_hits_metric_total[$__range])) + sum(increase(litellm_cache_misses_metric_total[$__range])), 1)",
          "legendFormat": "Hit Ratio",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio (range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Time-to-first-token (p95) by backend model. LiteLLM reports this in seconds.",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 47 },
      "id": 29,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, model) (rate(litellm_llm_api_time_to_first_token_metric_bucket[$__rate_interval])))",
          "legendFormat": "{{model}} p95",
          "refId": "A"
        }
      ],
      "title": "Time to First Token p95 by Model",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Cache hits vs misses rate over time",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 47 },
      "id": 30,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(litellm_cache_hits_metric_total[$__rate_interval]))",
          "legendFormat": "hits/s",
