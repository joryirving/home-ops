      "description": "Real host RAM used, excluding free, cache, buffers, and reclaimable memory. Useful for UMA systems where GPU memory shows up as node memory pressure.",
      "fill": 0,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 33
      },
      "id": 16,
