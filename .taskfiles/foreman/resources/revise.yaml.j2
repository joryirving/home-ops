---
apiVersion: foreman.llmkube.dev/v1alpha1
kind: AgenticTask
metadata:
  name: {{ ENV.NAME }}
  namespace: {{ ENV.NS }}
  labels:
    app.kubernetes.io/managed-by: foreman-adhoc
    foreman.llmkube.dev/adhoc: "true"
spec:
  kind: issue-fix
  agentRef:
    name: {{ ENV.CODER }}
  payload:
    repo: {{ ENV.REPO }}
    issue: {{ ENV.ISSUE }}
    branch: {{ ENV.BRANCH }}
    reviseFromBranch: {{ ENV.BRANCH }}
    baseBranch: {{ ENV.BASE }}
    prompt: |
      Revise the EXISTING branch to address the feedback below. The prior attempt
      is already checked out — do NOT start over; make the smallest targeted edits
      on top and keep everything the feedback does not object to.

      {{ ENV.FEEDBACK | indent(6) }}
